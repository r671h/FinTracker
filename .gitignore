# Delete the broken one and create a clean one
Set-Content .gitignore -Encoding UTF8 -Value @"
node_modules/
.pnp
.pnp.js

.env
.env.local
.env.development.local
.env.test.local
.env.production.local

frontend/.next/
frontend/out/
frontend/build/
frontend/.vercel

backend/dist/
build/
dist/

logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

.DS_Store
Thumbs.db
desktop.ini

.vscode/
.idea/

coverage/

*.zip
*.tgz
.cache/
"@